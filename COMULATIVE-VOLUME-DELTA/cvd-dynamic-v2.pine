//@version=6
indicator("CVD: Architect", "CVD_Arch", format=format.volume, precision=0)

// ==========================================
// 1. ARCHITECT DYNAMIC ENGINE
// ==========================================
groupArch = "ACTIVE INTELLIGENCE"
useAuto   = input.bool(true, "ACTIVATE ARCHITECT MODE", group=groupArch, tooltip="Automatically adjusts the reset period based on your current timeframe.")

// Detect chart timeframe in minutes
float tf_minutes = timeframe.multiplier / (timeframe.isseconds ? 60 : 1)
if timeframe.isdaily
    tf_minutes := 1440
else if timeframe.isweekly
    tf_minutes := 10080
else if timeframe.ismonthly
    tf_minutes := 43200

// Automatic Anchor Selection Logic (Reset Period)
string auto_anchor = "D"

if tf_minutes <= 5
    // Scalping (1m-5m) -> Daily Reset
    auto_anchor := "D" 
else if tf_minutes > 5 and tf_minutes <= 60
    // Intraday (15m-1H) -> Weekly Reset
    auto_anchor := "W"
else if tf_minutes > 60 and tf_minutes <= 240
    // Short Swing (4H) -> Monthly Reset
    auto_anchor := "M"
else
    // Macro -> Quarterly Reset
    auto_anchor := "3M" 

// ==========================================
// 2. MANUAL SETTINGS AND COMPATIBILITY
// ==========================================
groupMan = "MANUAL SETTINGS"
manAnchor = input.timeframe("1D", "Manual Anchor", group=groupMan)
useCustomLTF = input.bool(false, "Force Scan Timeframe", group=groupMan)
customLTF = input.timeframe("1", "Manual Scan Timeframe", group=groupMan)

// Final Resolution
finalAnchor = useAuto ? auto_anchor : manAnchor

// Selection of Internal Timeframe (Microscope)
var string calc_tf = "1"

if not useCustomLTF
    // Free accounts logic: We use "1" (1 minute) as the absolute minimum.
    if tf_minutes < 1
        calc_tf := "1" // Protection against seconds errors
    else if tf_minutes <= 5
        calc_tf := "1" // In 1m and 5m, use 1 minute data.
    else
        calc_tf := "1" // Default to 1 minute for maximum allowed precision.
else
    calc_tf := customLTF

// ==========================================
// 3. DELTA CALCULATION ENGINE (WITH WICKS)
// ==========================================

// Request internal data
[ltf_o, ltf_c, ltf_v] = request.security_lower_tf(syminfo.tickerid, calc_tf, [open, close, volume])

// Persistent variables for CVD accumulation
var float cvd_open  = 0.0
var float cvd_high  = 0.0
var float cvd_low   = 0.0
var float cvd_close = 0.0

bool is_reset = timeframe.change(finalAnchor)

// Reset or Transition logic
if is_reset
    cvd_open  := 0.0
    cvd_close := 0.0
else
    cvd_open := cvd_close 

// Tracking wicks by iterating through LTF data
float running_sum = cvd_open
cvd_high := cvd_open
cvd_low  := cvd_open

if array.size(ltf_c) > 0
    for i = 0 to array.size(ltf_c) - 1
        float _o = array.get(ltf_o, i)
        float _c = array.get(ltf_c, i)
        float _v = array.get(ltf_v, i)
        
        // Calculate sub-candle delta
        float sub_delta = _c >= _o ? _v : -_v
        
        // Update running total
        running_sum += sub_delta
        
        // Track High/Low peaks achieved during the bar duration
        cvd_high := math.max(cvd_high, running_sum)
        cvd_low  := math.min(cvd_low, running_sum)

cvd_close := running_sum
float bar_delta = cvd_close - cvd_open

// ==========================================
// 4. VISUALIZATION (MONOCHROME)
// ==========================================

color bullColor = #FFFFFF // Pure White (Strength)
color bearColor = #787B86 // Institutional Grey (Weakness)

// Color determination based on Bar Delta
color finalColor = bar_delta >= 0 ? bullColor : bearColor

// Plotting CVD Candles with Wicks
plotcandle(cvd_open, cvd_high, cvd_low, cvd_close, "CVD Candles", color=finalColor, wickcolor=finalColor, bordercolor=finalColor)

// Reference Zero Line
hline(0, "Zero Line", color=color.new(color.white, 70), linestyle=hline.style_dotted)

// ==========================================
// 5. CONTROL PANEL (HUD)
// ==========================================
var table dash = table.new(position.top_right, 3, 2, bgcolor=color.new(color.black, 60), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(dash, 0, 0, "CVD MODE", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 0, useAuto ? "AUTO" : "MANUAL", text_color=useAuto ? color.white : color.gray, text_size=size.small)
    
    table.cell(dash, 0, 1, "RESET", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 1, finalAnchor, text_color=color.white, text_size=size.small)
