indicator("Deep Chart + BB + EMAs (Pro Architect)", shorttitle = "DeepBB_EMA_PRO", overlay = true, max_labels_count = 500)

groupEMA = "Medias Móviles Exponenciales"
showEMAs = input.bool(true, "Mostrar EMAs", group=groupEMA)
len21    = input.int(21, "EMA Corta (21)", minval=1, group=groupEMA)
len50    = input.int(50, "EMA Media (50)", minval=1, group=groupEMA)
len200   = input.int(200, "EMA Larga (200)", minval=1, group=groupEMA)

ema21 = ta.ema(close, len21)
ema50 = ta.ema(close, len50)
ema200 = ta.ema(close, len200)

groupBB = "Bollinger Bands"
bbLength = input.int(20, "Longitud BB", minval=1, group=groupBB)
bbMult   = input.float(2.0, "Desviación Std", group=groupBB)
bbSrc    = input(close, "Fuente BB", group=groupBB)
bbMaType = input.string("SMA", "Tipo de Base", options = ["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group=groupBB)

ma_func(source, length, _type) =>
    switch _type
        "SMA"        => ta.sma(source, length)
        "EMA"        => ta.ema(source, length)
        "SMMA (RMA)" => ta.rma(source, length)
        "WMA"        => ta.wma(source, length)
        "VWMA"       => ta.vwma(source, length)

basis = ma_func(bbSrc, bbLength, bbMaType)
dev   = bbMult * ta.stdev(bbSrc, bbLength)
upper = basis + dev
lower = basis - dev

groupDeep = "Deep Chart (Burbujas de Volumen)"
volThreshold  = input.float(1.5, "Sensibilidad de Volumen", minval = 0.5, step = 0.1, group=groupDeep, tooltip="1.0 = Promedio. 2.0 = Doble del volumen normal.")
volLookback   = input.int(50, "Memoria de Volumen", minval=10, group=groupDeep)
minBubbleSize = input.string(size.tiny, "Tamaño Mínimo", options=[size.tiny, size.small, size.normal], group=groupDeep)

basisPlot = plot(basis, "BB Basis", color=color.new(color.white, 50), linestyle = plot.linestyle_dashed)
pUpper    = plot(upper, "BB Upper", color=color.new(color.red, 50))
pLower    = plot(lower, "BB Lower", color=color.new(color.teal, 50))

float buyVol  = close > open ? volume : 0
float sellVol = close < open ? volume : 0
cvdColor      = close > open ? color.new(color.teal, 92) : color.new(color.red, 92)
fill(pUpper, pLower, title = "Fondo de Volatilidad", color = cvdColor)

ema21Plot = plot(showEMAs ? ema21 : na, "EMA 21", color=color.new(#fffc31, 20), linewidth=2)
plot(showEMAs ? ema50 : na, "EMA 50", color=color.new(#00d9c0, 20), linewidth=2)
plot(showEMAs ? ema200 : na, "EMA 200", color=color.new(#8600ce, 0), linewidth=2)

fill(ema21Plot, basisPlot, title="Fuerza de Tendencia", color = ema21 > basis ? color.new(color.lime, 85) : color.new(color.red, 85))

var string ltf = timeframe.isseconds ? "1S" : timeframe.isintraday ? (timeframe.multiplier <= 5 ? "1" : "5") : "60"

ltf_close = request.security_lower_tf(syminfo.tickerid, ltf, close)
ltf_open  = request.security_lower_tf(syminfo.tickerid, ltf, open)
ltf_vol   = request.security_lower_tf(syminfo.tickerid, ltf, volume)

chartAvgVol = ta.sma(volume, volLookback) 
ltf_ratio   = array.size(ltf_close) 
baselineVol = ltf_ratio > 0 ? (chartAvgVol / ltf_ratio) : 0

if ltf_ratio > 0 and baselineVol > 0
    for i = 0 to ltf_ratio - 1
        float v  = array.get(ltf_vol, i)
        float c  = array.get(ltf_close, i)
        float o  = array.get(ltf_open, i)

        if v > (baselineVol * volThreshold)
            bool isBuy = c >= o
            string bSize = v > (baselineVol * volThreshold * 5) ? size.large : v > (baselineVol * volThreshold * 3) ? size.normal : minBubbleSize
            color bColor = isBuy ? color.new(color.teal, 40) : color.new(color.red, 40)

            label.new(
                 bar_index, c, 
                 text = "", 
                 style = label.style_circle, 
                 color = bColor, 
                 size = bSize,
                 tooltip = "Vol: " + str.tostring(v, format.volume)
             )

anomaly = volume > (chartAvgVol * 2)
plotshape(anomaly and close > open, "Absorción/Iniciativa Compra", shape.triangleup, location.belowbar, color.lime, size=size.tiny)
plotshape(anomaly and close < open, "Absorción/Iniciativa Venta", shape.triangledown, location.abovebar, color.red, size=size.tiny)
